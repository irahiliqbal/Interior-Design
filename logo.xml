<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 90" width="320" height="90">
  <defs>
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Great+Vibes&family=Raleway:wght@300;400&display=swap');
      .script { font-family: 'Great Vibes', cursive; }
      .sub    { font-family: 'Raleway', sans-serif; }
    </style>
    <linearGradient id="g" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%"   stop-color="#a8864a"/>
      <stop offset="50%"  stop-color="#C9A96E"/>
      <stop offset="100%" stop-color="#e2c99a"/>
    </linearGradient>
  </defs>

  <!-- Dark background version -->
  <rect width="320" height="90" fill="#111111" rx="6"/>

  <!-- "Qasim" in Great Vibes script -->
  <text x="16" y="58"
    class="script"
    font-size="52"
    fill="url(#g)"
    letter-spacing="1">Qasim</text>

  <!-- "HOME DECORATION" subtitle -->
  <text x="18" y="76"
    class="sub"
    font-size="9"
    font-weight="400"
    fill="#888880"
    letter-spacing="4">HOME DECORATION</text>

</svg>